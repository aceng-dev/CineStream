<?xml version="1.0" encoding="utf-8"?>
<!--
    FILE: item_film.xml
    LOKASI: res/layout/item_film.xml
    FUNGSI: Tampilan satu item kartu film di RecyclerView (gaya Netflix/IMDb)
    SINKRON DENGAN: FilmApi.java (field: judul, gambar_poster, skor_rating, kategori)
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#1C1C1C">

    <!--
        Root: LinearLayout horizontal
        Kiri  = poster film (gambar_poster via Glide)
        Kanan = info film (judul, kategori, skor_rating)
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- POSTER FILM (kiri) -->
        <!-- Diisi oleh Glide di FilmAdapter.java menggunakan getGambarPoster() -->
        <ImageView
            android:id="@+id/imgPoster"
            android:layout_width="80dp"
            android:layout_height="110dp"
            android:scaleType="centerCrop"
            android:background="#2A2A2A"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- INFORMASI FILM (kanan) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical">

            <!-- JUDUL FILM -->
            <!-- Diisi: FilmApi.getJudul() -->
            <TextView
                android:id="@+id/txtJudul"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Judul Film"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- KATEGORI / GENRE -->
            <!-- Diisi: FilmApi.getKategori() -->
            <TextView
                android:id="@+id/txtKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Aksi"
                android:textColor="#E50914"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tag_kategori"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"/>

            <!-- SKOR RATING -->
            <!-- Diisi: FilmApi.getSkorRating() -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <!-- Bintang kuning -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★"
                    android:textColor="#F5C518"
                    android:textSize="14sp"/>

                <!-- Angka rating -->
                <TextView
                    android:id="@+id/txtRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="8.5"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"/>

                <!-- STATUS NONTON (LOKAL) -->
                <TextView
                    android:id="@+id/txtStatusNonton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="✓ Ditonton"
                    android:textColor="#00FF00"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

        <!-- PANAH / CHEVRON (kanan ujung) -->
        <!-- Penanda visual bahwa item bisa diklik ke halaman detail -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="›"
            android:textColor="#555555"
            android:textSize="24sp"
            android:paddingStart="8dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
